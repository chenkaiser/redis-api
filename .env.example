# Auth provider: 'keycloak' | 'entra-id'
AUTH_PROVIDER_TYPE=keycloak
NODE_ENV=development
LOG_LEVEL=info

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka
KAFKA_BROKER=localhost:9092

# ── Keycloak admin console ─────────────────────────────────────────────────────
# Credentials for the Keycloak master-realm admin user.
KEYCLOAK_ADMIN_USER=change-me
KEYCLOAK_ADMIN_PASSWORD=change-me

# ── Keycloak OIDC / JWT (required when AUTH_PROVIDER_TYPE=keycloak) ───────────
KEYCLOAK_JWKS_URI=http://localhost:8080/realms/redis-api/protocol/openid-connect/certs
KEYCLOAK_ISSUER=http://localhost:8080/realms/redis-api
KEYCLOAK_AUDIENCE=product-api
# Internal URL used by the API to reach Keycloak inside Docker.
# Use http://keycloak:8080 in Docker Compose, http://localhost:8080 for local dev.
KEYCLOAK_INTERNAL_URL=http://localhost:8080
KEYCLOAK_REALM=redis-api
KEYCLOAK_LOGIN_CLIENT_ID=api-test
KEYCLOAK_ADMIN_CLIENT_ID=auth-service
# Secret for the auth-service Keycloak client — never commit the real value.
KEYCLOAK_ADMIN_CLIENT_SECRET=change-me
# Secret for the order-consumer Keycloak client — never commit the real value.
ORDER_CONSUMER_CLIENT_SECRET=change-me

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=change-me
POSTGRES_PASSWORD=change-me
POSTGRES_DB=orders

# ── Azure Entra ID (required when AUTH_PROVIDER_TYPE=entra-id) ────────────────
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
