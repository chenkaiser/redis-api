{
  "realm": "redis-api",
  "enabled": true,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "requiredActions": [
    { "alias": "CONFIGURE_TOTP",   "name": "Configure OTP",       "providerId": "CONFIGURE_TOTP",   "enabled": true,  "defaultAction": false, "priority": 10, "config": {} },
    { "alias": "UPDATE_PASSWORD",  "name": "Update Password",     "providerId": "UPDATE_PASSWORD",  "enabled": true,  "defaultAction": false, "priority": 30, "config": {} },
    { "alias": "UPDATE_PROFILE",   "name": "Update Profile",      "providerId": "UPDATE_PROFILE",   "enabled": true,  "defaultAction": false, "priority": 40, "config": {} },
    { "alias": "VERIFY_EMAIL",     "name": "Verify Email",        "providerId": "VERIFY_EMAIL",     "enabled": true,  "defaultAction": false, "priority": 50, "config": {} },
    { "alias": "VERIFY_PROFILE",   "name": "Verify Profile",      "providerId": "VERIFY_PROFILE",   "enabled": true,  "defaultAction": false, "priority": 90, "config": {} },
    { "alias": "delete_account",   "name": "Delete Account",      "providerId": "delete_account",   "enabled": false, "defaultAction": false, "priority": 60, "config": {} },
    { "alias": "terms_and_conditions", "name": "Terms and Conditions", "providerId": "terms_and_conditions", "enabled": false, "defaultAction": false, "priority": 20, "config": {} }
  ],

  "roles": {
    "realm": [
      {
        "name": "product:read",
        "description": "Read inventory data",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "product:write",
        "description": "Consume inventory items and publish events",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "product:admin",
        "description": "Full admin access — includes product:read and product:write",
        "composite": true,
        "composites": {
          "realm": ["product:read", "product:write"]
        },
        "clientRole": false
      }
    ]
  },

  "clients": [
    {
      "clientId": "product-api",
      "name": "Product API (Resource Server)",
      "description": "Resource server — validates incoming bearer tokens. Does not issue tokens.",
      "enabled": true,
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect"
    },
    {
      "clientId": "order-consumer",
      "name": "Order Consumer (Service Account)",
      "description": "Confidential client for service-to-service calls using Client Credentials flow.",
      "enabled": true,
      "publicClient": false,
      "secret": "to-be-set-by-init",
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "audience-product-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "product-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "auth-service",
      "name": "Auth Service (User Management)",
      "description": "Confidential client used by product-api to create users via Admin API.",
      "enabled": true,
      "publicClient": false,
      "secret": "to-be-set-by-init",
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect"
    },
    {
      "clientId": "api-test",
      "name": "API Test Client (Dev Only)",
      "description": "Public client with Resource Owner Password Grant — for local testing and Swagger UI only. Remove in production.",
      "enabled": true,
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "audience-product-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "product-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],

  "users": [
    {
      "username": "testuser",
      "firstName": "Test",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "email": "testuser@local.dev",
      "requiredActions": [],
      "credentials": [
        { "type": "password", "value": "testuser123", "temporary": false }
      ],
      "realmRoles": ["product:write"]
    },
    {
      "username": "adminuser",
      "firstName": "Admin",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "email": "adminuser@local.dev",
      "requiredActions": [],
      "credentials": [
        { "type": "password", "value": "adminuser123", "temporary": false }
      ],
      "realmRoles": ["product:admin"]
    },
    {
      "username": "service-account-order-consumer",
      "enabled": true,
      "serviceAccountClientId": "order-consumer",
      "requiredActions": [],
      "realmRoles": ["product:write"]
    },
    {
      "username": "service-account-auth-service",
      "enabled": true,
      "serviceAccountClientId": "auth-service",
      "requiredActions": [],
      "clientRoles": {
        "realm-management": ["manage-users", "view-users", "query-users", "view-realm"]
      }
    }
  ]
}
